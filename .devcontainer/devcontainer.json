{
  "name": "SONiC Lab Workbook",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false,
      "installDockerBuildx": false,
      "version": "latest"
    }
  },
  // --privileged: required for containerlab to create virtual interfaces.
  // --pid=host: shares the host PID namespace so containerlab can access
  //   /proc/<pid>/ns/net of sibling containers it creates via the Docker socket.
  //   Without this, link creation fails in Codespaces and docker-outside-of-docker
  //   setups with: "failed to Statfs /proc/<pid>/ns/net: no such file or directory"
  "runArgs": [
    "--privileged",
    "--pid=host"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-vscode.makefile-tools",
        "srl-labs.vscode-containerlab"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "yaml.schemas": {
          "https://raw.githubusercontent.com/srl-labs/containerlab/main/schemas/clab.schema.json": "labs/**/*.yml"
        }
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
